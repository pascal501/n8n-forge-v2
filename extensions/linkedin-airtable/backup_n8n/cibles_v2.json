    {
      "parameters": {
        "jsCode": "// Moteur de cibles Shodo - Adzuna vers Airtable Comptes Cibles\n// Cle Adzuna via variables d'environnement (ADZUNA_APP_ID / ADZUNA_APP_KEY)\n\nconst APP_ID  = $env.ADZUNA_APP_ID;\nconst APP_KEY = $env.ADZUNA_APP_KEY;\n\nconst bassins = [\n  { where: 'Rennes', distance: 80, bassin: 'Grande Region Rennes', assigne: 'Laurene' },\n  { where: 'Nantes', distance: 80, bassin: 'Grande Region Nantes', assigne: 'Adrien'  }\n];\n\nconst PAGES = 3;\nconst MAX_DAYS_OLD = 2;\nconst DEPTS_OK = ['35','56','22','29','44','49','85'];\nconst NAF_ESN = ['62.01Z','62.02A','62.02B','62.03Z','62.09Z','70.22Z'];\nconst NAF_RECRUT = ['78.10Z','78.20Z','78.30Z'];\n\n// Clients ACTUELS de Shodo a exclure (a completer)\nconst EXCLUSION_SHODO = [];\n\nfunction stacks(title){\n  const t = (title || '').toLowerCase();\n  const out = [];\n  if (/java/.test(t)) out.push('Java');\n  if (/\\.net|c#|dotnet/.test(t)) out.push('.NET');\n  if (/python/.test(t)) out.push('Python');\n  if (/\\bdata\\b|big data/.test(t)) out.push('Data');\n  if (/\\bia\\b|machine learning|\\bml\\b|data scien|llm/.test(t)) out.push('IA / ML');\n  if (/devops|sre|kubernetes|docker/.test(t)) out.push('DevOps');\n  if (/architect/.test(t)) out.push('Architecture');\n  if (/chef de projet|product owner|scrum master/.test(t)) out.push('Chef de projet');\n  if (/cloud|aws|azure|gcp/.test(t)) out.push('Cloud');\n  if (/mobile|android|ios|flutter/.test(t)) out.push('Mobile');\n  if (/front|react|angular|vue/.test(t)) out.push('Front');\n  return out.length ? out : ['Autre'];\n}\n\nconst http = this.helpers.httpRequest;\nconst out = [];\n\nfor (const b of bassins) {\n  for (let i = 0; i !== PAGES; i++) {\n    const page = i + 1;\n    let res;\n    try {\n      res = await http({\n        method: 'GET',\n        url: 'https://api.adzuna.com/v1/api/jobs/fr/search/' + page,\n        qs: {\n          app_id: APP_ID,\n          app_key: APP_KEY,\n          where: b.where,\n          distance: b.distance,\n          category: 'it-jobs',\n          max_days_old: MAX_DAYS_OLD,\n          results_per_page: 50,\n          sort_by: 'date'\n        },\n        json: true\n      });\n    } catch (e) { continue; }\n\n    for (const job of (res.results || [])) {\n      const company = ((job.company && job.company.display_name) || '').trim();\n      if (!company) continue;\n\n      let skip = false;\n      for (const c of EXCLUSION_SHODO) {\n        if (company.toLowerCase().indexOf(c.toLowerCase()) !== -1) skip = true;\n      }\n      if (skip) continue;\n\n      let siren = '';\n      let naf = '';\n      let ville = (job.location && job.location.display_name) || '';\n      let cp = '';\n      try {\n        const ent = await http({\n          method: 'GET',\n          url: 'https://recherche-entreprises.api.gouv.fr/search',\n          qs: { q: company, per_page: 1 },\n          json: true\n        });\n        const e = ent.results && ent.results[0];\n        if (e) {\n          siren = e.siren || '';\n          naf = (e.siege && e.siege.activite_principale) || e.activite_principale || '';\n          ville = (e.siege && e.siege.libelle_commune) || ville;\n          cp = (e.siege && e.siege.code_postal) || '';\n        }\n      } catch (e) {}\n\n      let type = 'Client final';\n      if (NAF_ESN.indexOf(naf) !== -1) type = 'ESN';\n      else if (NAF_RECRUT.indexOf(naf) !== -1) type = 'Cabinet recrutement';\n      else if (!naf) type = 'Inconnu';\n\n      if (type === 'ESN' || type === 'Cabinet recrutement') continue;\n\n      let dept = cp ? cp.substring(0,2) : '';\n      if (DEPTS_OK.indexOf(dept) === -1) dept = 'Autre';\n\n      const dateSignal = (job.created || '').substring(0,10);\n\n      out.push({ json: {\n        'Entreprise': company,\n        'SIREN / SIRET': siren,\n        'Code NAF': naf,\n        'Type entreprise': type,\n        'Ville': ville,\n        'Departement': dept,\n        'Bassin': b.bassin,\n        'Assigne a': b.assigne,\n        'Signal achat': job.title + ' - ' + b.where + ' (Adzuna, ' + dateSignal + ')',\n        'Intitule poste': job.title || '',\n        'Profils Stack': stacks(job.title),\n        'Date du signal': dateSignal,\n        'Source': 'Adzuna',\n        'Lien offre': job.redirect_url || ''\n      }});\n    }\n  }\n}\nreturn out;\n"
      },
