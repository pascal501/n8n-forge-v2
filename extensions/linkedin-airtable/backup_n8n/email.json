    {
      "parameters": {
        "jsCode": "// Filtre contacts Rennes/Nantes sans Email\nconst items = $input.all();\nconst out = [];\n\nconst geo_targets = ['rennes', 'bretagne', 'nantes', 'loire', 'pays de la loire', 'ille et vilaine', 'loire-atlantique'];\n\nfor (let i = 0; i !== items.length; i++) {\n  const f = items[i].fields;\n  \n  // Skip si Email existe\n  if (f.Email && f.Email.trim().length > 0) continue;\n  \n  const loc = (f.Location || '').toLowerCase();\n  \n  // Check si location correspond\n  let match = false;\n  for (let g = 0; g !== geo_targets.length; g++) {\n    if (loc.indexOf(geo_targets[g]) !== -1) { match = true; break; }\n  }\n  if (!match) continue;\n  \n  out.push({ json: {\n    record_id: items[i].id,\n    prenom: f.Prenom || '',\n    nom: f.Nom || '',\n    entreprise: f.Entreprise || ''\n  }});\n}\nreturn out;\n"
      },
