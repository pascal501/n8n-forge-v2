    {
      "parameters": {
        "jsCode": "// Extrait localisation de SIRENE + fallback Apollo\nconst items = $input.all();\nconst out = [];\n\nconst depts_fr = {\n  '35': 'Ille-et-Vilaine', '56': 'Morbihan', '22': 'Cotes-d-Armor', '29': 'Finistere',\n  '44': 'Loire-Atlantique', '49': 'Maine-et-Loire', '85': 'Vendee', '72': 'Sarthe'\n};\n\nconst regions_fr = {\n  '35': 'Bretagne', '56': 'Bretagne', '22': 'Bretagne', '29': 'Bretagne',\n  '44': 'Pays de la Loire', '49': 'Pays de la Loire', '85': 'Pays de la Loire', '72': 'Pays de la Loire'\n};\n\nfor (let i = 0; i !== items.length; i++) {\n  const item = items[i];\n  let location = '';\n  \n  // Essai SIRENE d'abord\n  if (item.sirene_response && item.sirene_response.results && item.sirene_response.results.length > 0) {\n    const e = item.sirene_response.results[0];\n    if (e.siege && e.siege.code_postal) {\n      const cp = e.siege.code_postal.substring(0, 2);\n      location = regions_fr[cp] || 'France';\n    } else if (e.siege && e.siege.libelle_commune) {\n      location = e.siege.libelle_commune;\n    }\n  }\n  \n  // Fallback Apollo si pas SIRENE\n  if (!location && item.apollo_response && item.apollo_response.people && item.apollo_response.people.length > 0) {\n    const p = item.apollo_response.people[0];\n    if (p.city) location = p.city;\n    else if (p.state) location = p.state;\n    else if (p.country) location = p.country;\n  }\n  \n  if (location) {\n    out.push({ json: {\n      record_id: item.record_id,\n      Location: location\n    }});\n  }\n}\nreturn out;\n"
      },
