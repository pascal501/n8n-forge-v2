      "parameters": {
        "jsCode": "// Filtre contacts sans Location\nconst items = $input.all();\nconst out = [];\n\nfor (let i = 0; i !== items.length; i++) {\n  const f = items[i].fields;\n  // Skip si Location deja rempli\n  if (f.Location && f.Location.trim().length > 0) continue;\n  \n  out.push({ json: {\n    record_id: items[i].id,\n    nom: f.Nom || '',\n    prenom: f.Prenom || '',\n    entreprise: f.Entreprise || ''\n  }});\n}\nreturn out;\n"
      },
