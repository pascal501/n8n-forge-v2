{
  "manifest_version": 3,
  "name": "LinkedIn Profiler → Airtable",
  "version": "2.0.0",
  "description": "Importe et enrichit les profils LinkedIn dans Airtable — mode manuel et batch",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "windows"
  ],

  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://api.airtable.com/*",
    "https://content.airtable.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://*.licdn.com/*",
    "https://openrouter.ai/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn → Airtable",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/in/*",
        "https://*.linkedin.com/company/*",
        "https://*.linkedin.com/feed/*",
        "https://*.linkedin.com/posts/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "options_page": "options.html"
}
