# ─── MCP ─────────────────────────────────────────────────────────────────────
# URL du serveur n8n-mcp (depuis le container Docker vers le host)
MCP_BASE_URL=http://host.docker.internal:3000

# Token d'authentification MCP (celui dans /home/paco/n8n-mcp/.env)
MCP_AUTH_TOKEN=PfoLinking10!

# ─── N8N (pour les liens "Ouvrir dans N8N") ──────────────────────────────────
N8N_PUBLIC_URL=https://usine.dinaou.com

# ─── IA ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# ─── SERVEUR ─────────────────────────────────────────────────────────────────
PORT=3001
# ALLOWED_ORIGIN=https://forge.dinaou.com
