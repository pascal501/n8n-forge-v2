    "express":    "^4.19.2",
    "node-fetch": "^2.7.0",
    "react":      "^18.3.1",
    "react-dom":  "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently":         "^8.2.2",
    "nodemon":              "^3.1.3",
    "vite":                 "^5.3.1"
  }
}
